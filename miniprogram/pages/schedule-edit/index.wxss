.form {
  padding: 32rpx;
}
.field {
  margin-bottom: 32rpx;
}
.label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}
.input {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 30rpx;
  border: 1rpx solid var(--border-light);
}
.textarea {
  width: 100%;
  box-sizing: border-box;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 30rpx;
  min-height: 120rpx;
  border: 1rpx solid var(--border-light);
}
.picker-val {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 30rpx;
  border: 1rpx solid var(--border-light);
  color: var(--text-primary);
}
.time-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.time-row picker {
  flex: 1;
}
.clear-btn {
  flex-shrink: 0;
  font-size: 26rpx;
  color: #6366f1;
  padding: 12rpx 20rpx;
}
.save-btn {
  margin-top: 48rpx;
  background: var(--agent-orchestrator);
  color: #fff;
  text-align: center;
  padding: 28rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
}
.save-btn.disabled { opacity: 0.6; }
.delete-btn {
  margin-top: 24rpx;
  text-align: center;
  padding: 24rpx;
  color: #EF4444;
  font-size: 28rpx;
}
