page { background: var(--bg-base); }
.page { padding: 0 0 200rpx; min-height: 100vh; }

.section {
  background: #fff; margin: 16rpx;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
}
.section-title {
  font-size: 26rpx; color: var(--text-secondary);
  padding: 12rpx 0;
}

.row {
  display: flex; align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}
.row:last-child { border-bottom: none; }
.label { width: 200rpx; font-size: 28rpx; }
.value { flex: 1; font-size: 28rpx; }
.input { flex: 1; font-size: 28rpx; }
.picker-display { flex: 1; font-size: 28rpx; color: var(--text-secondary); }
.clear-btn {
  color: var(--text-secondary); font-size: 36rpx;
  padding: 0 16rpx; line-height: 1;
}

.type-row { display: flex; gap: 12rpx; flex-wrap: wrap; padding: 8rpx 0 16rpx; }
.type-btn {
  padding: 12rpx 24rpx;
  background: #f5f5f7;
  color: var(--text-secondary);
  border-radius: 12rpx;
  font-size: 26rpx;
}
.type-btn.selected {
  background: var(--agent-orchestrator);
  color: #fff;
}

.textarea {
  width: 100%; box-sizing: border-box;
  background: #f5f5f7;
  padding: 16rpx; border-radius: 12rpx;
  font-size: 28rpx; line-height: 1.7;
  min-height: 240rpx;
}

.bottom {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff;
  padding: 20rpx 32rpx;
  border-top: 1rpx solid var(--border-light);
}
.save-btn {
  background: var(--agent-orchestrator); color: #fff;
  text-align: center; font-size: 30rpx; font-weight: 600;
  padding: 24rpx 0; border-radius: 12rpx;
}
.save-btn.disabled { opacity: 0.5; }
