.bind {
  padding: 120rpx 60rpx;
  background: var(--bg-base);
  min-height: 100vh;
}
.title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 30rpx;
}
.hint {
  color: var(--text-secondary);
  font-size: 28rpx;
  line-height: 1.7;
  margin-bottom: 80rpx;
}
.bind-btn {
  background: var(--agent-orchestrator);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 12rpx;
}
.error {
  margin-top: 40rpx;
  color: #DC2626;
  font-size: 26rpx;
  text-align: center;
}
.contact {
  margin-top: 100rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
  text-align: center;
}
