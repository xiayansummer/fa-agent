<view class="chat">
  <scroll-view scroll-y class="messages" scroll-into-view="{{scrollToView}}" scroll-with-animation>
    <block wx:for="{{messages}}" wx:key="id">
      <view id="{{item.id}}">
        <block wx:if="{{item.kind === 'user'}}">
          <image wx:if="{{item.imageUrl}}" class="user-image" src="{{item.imageUrl}}" mode="widthFix" bindtap="onPreviewImage" data-url="{{item.imageUrl}}" />
          <view wx:if="{{item.text}}" class="user-bubble">{{item.text}}</view>
        </block>
        <rich-text wx:elif="{{item.kind === 'agent_text'}}"
                   class="agent-text agent-{{item.agent || 'content'}}"
                   nodes="{{item.bodyHtml}}"
                   space="nbsp" />

        <thinking
          wx:elif="{{item.kind === 'thinking'}}"
          agent="{{item.agent}}"
          label="{{item.thinkingLabel || '正在思考'}}" />
        <agent-card
          wx:elif="{{item.kind === 'agent_card'}}"
          agent="{{item.agent}}"
          title="{{item.title}}"
          body="{{item.body}}"
          actions="{{item.actions}}"
          show-status="{{item.showStatus}}"
          inline-editable="{{item.inlineEditable}}"
          bind:action="onCardAction" />
      </view>
    </block>
  </scroll-view>

  <view class="pending-chip" wx:if="{{pendingFile}}">
    <text class="chip-icon">📎</text>
    <text class="chip-name">{{pendingFile.name}}</text>
    <view class="chip-clear" catchtap="onClearPending">×</view>
  </view>

  <view class="input-bar">
    <view class="plus-btn" bindtap="onPlusTap">+</view>
    <input
      class="input"
      value="{{input}}"
      bindinput="onInput"
      placeholder="{{pendingFile ? '发送指令（如挂到红杉机构）...' : '问 Agent 任何事...'}}"
      confirm-type="send"
      bindconfirm="onSend" />
    <view class="send-btn" bindtap="onSend">发送</view>
  </view>
</view>

<review-full-modal
  visible="{{modalVisible}}"
  agent-title="{{modalAgentTitle}}"
  body="{{modalBody}}"
  bind:close="onModalClose"
  bind:action="onModalAction" />
