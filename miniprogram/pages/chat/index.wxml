<view class="chat">
  <scroll-view scroll-y class="messages" scroll-into-view="{{scrollToView}}" scroll-with-animation>
    <block wx:for="{{messages}}" wx:key="id">
      <view id="{{item.id}}">
        <view wx:if="{{item.kind === 'user'}}" class="user-bubble">{{item.text}}</view>
        <rich-text wx:elif="{{item.kind === 'agent_text'}}"
                   class="agent-text agent-{{item.agent || 'content'}}"
                   nodes="{{item.bodyHtml}}"
                   space="nbsp" />

        <thinking
          wx:elif="{{item.kind === 'thinking'}}"
          agent="{{item.agent}}"
          label="{{item.thinkingLabel || '正在思考'}}" />
        <agent-card
          wx:elif="{{item.kind === 'agent_card'}}"
          agent="{{item.agent}}"
          title="{{item.title}}"
          body="{{item.body}}"
          actions="{{item.actions}}"
          show-status="{{item.showStatus}}"
          inline-editable="{{item.inlineEditable}}"
          bind:action="onCardAction" />
      </view>
    </block>
  </scroll-view>

  <view class="input-bar">
    <input
      class="input"
      value="{{input}}"
      bindinput="onInput"
      placeholder="问 Agent 任何事..."
      confirm-type="send"
      bindconfirm="onSend" />
    <view class="send-btn" bindtap="onSend">发送</view>
  </view>
</view>

<review-full-modal
  visible="{{modalVisible}}"
  agent-title="{{modalAgentTitle}}"
  body="{{modalBody}}"
  bind:close="onModalClose"
  bind:action="onModalAction" />
