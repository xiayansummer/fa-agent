<view class="chat">
  <view class="new-session-btn" bindtap="onNewSession">⊕ 新会话</view>
  <scroll-view scroll-y class="messages" scroll-into-view="{{scrollToView}}" scroll-with-animation>
    <block wx:for="{{messages}}" wx:key="id">
      <view id="{{item.id}}">
        <block wx:if="{{item.kind === 'user'}}">
          <image wx:if="{{item.imageUrl}}" class="user-image" src="{{item.imageUrl}}" mode="widthFix" bindtap="onPreviewImage" data-url="{{item.imageUrl}}" />
          <view wx:if="{{item.text}}" class="user-bubble"
                bindlongpress="onMsgLongPress" data-text="{{item.text}}">{{item.text}}</view>
        </block>
        <rich-text wx:elif="{{item.kind === 'agent_text'}}"
                   class="agent-text agent-{{item.agent || 'content'}}"
                   nodes="{{item.bodyHtml}}"
                   bindlongpress="onMsgLongPress" data-text="{{item.body}}"
                   space="nbsp" />

        <thinking
          wx:elif="{{item.kind === 'thinking'}}"
          agent="{{item.agent}}"
          label="{{item.thinkingLabel || '正在思考'}}" />
        <agent-card
          wx:elif="{{item.kind === 'agent_card'}}"
          id="card-{{item.id}}"
          agent="{{item.agent}}"
          title="{{item.title}}"
          body="{{item.body}}"
          actions="{{item.actions}}"
          show-status="{{item.showStatus}}"
          inline-editable="{{item.inlineEditable}}"
          bind:action="onCardAction" />
      </view>
    </block>
  </scroll-view>

  <!-- 已附加预览：图片显缩略图，文档/音频显图标+文件名 -->
  <view wx:if="{{pendingFile}}" class="pending-preview">
    <image
      wx:if="{{pendingFile.purpose === 'image'}}"
      class="pp-media"
      src="{{pendingFile.url}}"
      mode="aspectFill"
      bindtap="onPreviewImage"
      data-url="{{pendingFile.url}}" />
    <view wx:else class="pp-media pp-icon">{{pendingFile.purpose === 'audio' ? '🎵' : '📎'}}</view>
    <view class="pp-info">
      <view class="pp-name">{{pendingFile.name}}</view>
      <view class="pp-type">已附加 · {{pendingFile.purpose === 'image' ? '图片' : pendingFile.purpose === 'audio' ? '会议录音' : '文档'}},点发送处理</view>
    </view>
    <view class="pp-clear" catchtap="onClearPending">×</view>
  </view>

  <view class="input-bar">
    <view class="plus-btn {{pendingFile ? 'has-pending' : ''}}" bindtap="onPlusTap">+</view>
    <textarea
      class="input"
      value="{{input}}"
      bindinput="onInput"
      placeholder="{{pendingFile ? '已附加文件，发送指令...' : '问 Agent 任何事...'}}"
      auto-height
      show-confirm-bar="{{false}}"
      cursor-spacing="20"
      maxlength="-1" />
    <view class="send-btn" bindtap="onSend">发送</view>
  </view>
</view>

<review-full-modal
  id="review-modal"
  visible="{{modalVisible}}"
  agent-title="{{modalAgentTitle}}"
  body="{{modalBody}}"
  bind:close="onModalClose"
  bind:action="onModalAction" />

<!-- + 号自定义上传选择器：替换原 wx.showActionSheet -->
<view wx:if="{{pickerVisible}}" class="picker-mask" bindtap="onPickerCancel" catchtouchmove="onPickerCancel"></view>
<view class="picker-sheet {{pickerVisible ? 'show' : ''}}">
  <view class="picker-handle"></view>
  <view class="picker-title">添加内容</view>

  <view class="picker-item" data-type="text" bindtap="onPickerSelect">
    <view class="picker-icon bg-text">📋</view>
    <view class="picker-text">
      <view class="picker-label">粘贴文字</view>
      <view class="picker-sub">微信里长按消息→复制，回来点一下；可多次累加</view>
    </view>
  </view>

  <view class="picker-item" data-type="audio" bindtap="onPickerSelect">
    <view class="picker-icon bg-audio">🎵</view>
    <view class="picker-text">
      <view class="picker-label">会议录音</view>
      <view class="picker-sub">从微信聊天记录里选音频文件</view>
    </view>
  </view>

  <view class="picker-item" data-type="doc" bindtap="onPickerSelect">
    <view class="picker-icon bg-doc">📎</view>
    <view class="picker-text">
      <view class="picker-label">文档</view>
      <view class="picker-sub">BP / PDF / Word，从聊天记录里选</view>
    </view>
  </view>

  <view class="picker-item" data-type="image-album" bindtap="onPickerSelect">
    <view class="picker-icon bg-image">🖼️</view>
    <view class="picker-text">
      <view class="picker-label">图片</view>
      <view class="picker-sub">从相册选 / 拍一张</view>
    </view>
  </view>

  <view class="picker-item" data-type="image-chat" bindtap="onPickerSelect">
    <view class="picker-icon bg-chat">💬</view>
    <view class="picker-text">
      <view class="picker-label">图片（聊天记录）</view>
      <view class="picker-sub">从微信聊天里选图片</view>
    </view>
  </view>

  <view class="picker-cancel" bindtap="onPickerCancel">取消</view>
</view>
