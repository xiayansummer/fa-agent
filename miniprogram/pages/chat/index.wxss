page { background: var(--bg-base); }
.chat {
  display: flex; flex-direction: column;
  height: 100vh;
  padding-bottom: 0; /* 由 scroll-view 自己处理 */
}
.messages {
  flex: 1;
  padding: 32rpx;
  padding-top: 96rpx;     /* 给右上角「新会话」浮钮留空间 */
  padding-bottom: 140rpx; /* 给输入栏留空间 */
  height: 0;  /* flex shrinking 关键 */
}

.new-session-btn {
  position: fixed;
  top: 20rpx; right: 24rpx;
  z-index: 12;
  background: #fff;
  border: 1rpx solid var(--border-light);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  border-radius: 999rpx;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}
.new-session-btn:active { background: #f5f5f7; }

.user-bubble {
  align-self: flex-end;
  background: var(--agent-orchestrator); color: #fff;
  padding: 16rpx 24rpx; border-radius: 16rpx;
  max-width: 80%;
  margin: 8rpx 0 16rpx auto;
  font-size: 28rpx;
  line-height: 1.6;
  display: inline-block;
}
.user-image {
  display: block;
  max-width: 60%;
  margin: 16rpx 0 8rpx auto;
  border-radius: 16rpx;
  background: #f3f4f6;
}

.agent-text {
  display: block;
  background: #fff; padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx; line-height: 1.7;
  border-left: 8rpx solid var(--agent-content);
}
.agent-text.agent-orchestrator { border-left-color: #6B7AFF; }
.agent-text.agent-list         { border-left-color: #8B5CF6; }
.agent-text.agent-content      { border-left-color: #374151; }
.agent-text.agent-outreach     { border-left-color: #F59E0B; }

/* rich-text 内 markdown 样式（rich-text 不响应外部 class，用 element selector） */
.agent-text p          { margin: 0 0 10rpx 0; }
.agent-text p:last-child { margin-bottom: 0; }
.agent-text strong     { font-weight: 700; color: var(--text-primary); }
.agent-text em         { font-style: italic; }
.agent-text code       {
  background: #f4f4f5; color: #be185d;
  padding: 2rpx 8rpx; border-radius: 4rpx;
  font-size: 26rpx; font-family: monospace;
}
.agent-text ul, .agent-text ol { margin: 8rpx 0 12rpx 0; padding-left: 36rpx; }
.agent-text li         { margin: 4rpx 0; }
.agent-text h1, .agent-text h2, .agent-text h3 {
  font-weight: 700; margin: 16rpx 0 8rpx 0;
}
.agent-text h1 { font-size: 32rpx; }
.agent-text h2 { font-size: 30rpx; }
.agent-text h3 { font-size: 28rpx; }
.agent-text hr {
  border: none; border-top: 1rpx solid var(--border-light);
  margin: 16rpx 0;
}
.agent-text table {
  border-collapse: collapse;
  margin: 12rpx 0;
  font-size: 24rpx;
  width: 100%;
}
.agent-text th, .agent-text td {
  border: 1rpx solid var(--border-light);
  padding: 8rpx 12rpx;
  text-align: left;
  vertical-align: top;
}
.agent-text th { background: #f9fafb; font-weight: 600; }

.input-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff; padding: 20rpx 24rpx;
  display: flex; gap: 16rpx; align-items: flex-end;
  border-top: 1rpx solid var(--border-light);
  z-index: 10;
}
.plus-btn {
  flex-shrink: 0;
  width: 72rpx; height: 72rpx;
  background: #f5f5f7; border-radius: 50%;
  color: #6b7280; font-size: 40rpx; font-weight: 300;
  display: flex; align-items: center; justify-content: center;
  line-height: 1;
}
.plus-btn:active { background: #e5e7eb; }
.plus-btn.has-pending { background: #6366f1; color: #fff; }
.input {
  flex: 1;
  min-height: 72rpx;
  max-height: 280rpx;          /* 约 5-6 行，再长内部滚 */
  background: #f5f5f7;
  border-radius: 24rpx;        /* 不再用半圆，多行时观感更稳 */
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
}
.send-btn {
  background: var(--agent-orchestrator);
  color: #fff;
  padding: 0 32rpx;
  height: 72rpx; line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.pending-chip {
  position: fixed;
  left: 24rpx; right: 24rpx;
  bottom: 116rpx;
  background: #eef2ff; border: 1rpx solid #c7d2fe;
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
  display: flex; align-items: center; gap: 12rpx;
  font-size: 26rpx; color: #4338ca;
  z-index: 11;
}
.chip-icon { flex-shrink: 0; }
.chip-name { flex: 1; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.chip-clear {
  flex-shrink: 0;
  width: 40rpx; height: 40rpx; line-height: 36rpx; text-align: center;
  color: #6366f1; font-size: 32rpx; border-radius: 50%;
}
.chip-clear:active { background: #c7d2fe; }

/* ===== 已附加文件预览（input-bar 上方） ===== */
.pending-preview {
  position: fixed;
  left: 16rpx; right: 16rpx;
  /* input-bar 高约 112rpx + 16rpx 间距 */
  bottom: calc(128rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.10);
  padding: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  z-index: 9;
  border: 1rpx solid #e5e7eb;
}
.pp-media {
  width: 104rpx; height: 104rpx;
  border-radius: 12rpx;
  background: #f5f5f7;
  flex-shrink: 0;
}
.pp-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}
.pp-info {
  flex: 1;
  min-width: 0;
}
.pp-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 6rpx;
}
.pp-type {
  font-size: 22rpx;
  color: var(--text-secondary);
}
.pp-clear {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  background: #f5f5f7;
  text-align: center;
  line-height: 52rpx;
  font-size: 36rpx;
  color: #6b7280;
  flex-shrink: 0;
}
.pp-clear:active { background: #e5e7eb; }

/* ===== + 号上传选择器（底部弹出） ===== */
.picker-mask {
  position: fixed;
  left: 0; right: 0; top: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 100;
}
.picker-sheet {
  position: fixed;
  left: 0; right: 0;
  bottom: -100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 16rpx 0 calc(40rpx + env(safe-area-inset-bottom));
  z-index: 101;
  transition: bottom 0.25s ease-out;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.08);
}
.picker-sheet.show { bottom: 0; }
.picker-handle {
  width: 80rpx; height: 8rpx;
  background: #d4d4d8;
  border-radius: 4rpx;
  margin: 0 auto 16rpx;
}
.picker-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  text-align: center;
  padding: 0 32rpx 16rpx;
}
.picker-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 20rpx 32rpx;
}
.picker-item:active { background: #f5f5f7; }
.picker-icon {
  width: 88rpx; height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  line-height: 1;
  flex-shrink: 0;
}
.bg-text  { background: #fbcfe8; }   /* pink */
.bg-audio { background: #ddd6fe; }   /* lavender */
.bg-doc   { background: #fef3c7; }   /* amber */
.bg-image { background: #bfdbfe; }   /* blue */
.bg-chat  { background: #bbf7d0; }   /* green */
.picker-text { flex: 1; min-width: 0; }
.picker-label {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}
.picker-sub {
  font-size: 24rpx;
  color: var(--text-secondary);
}
.picker-cancel {
  margin: 24rpx 32rpx 0;
  padding: 28rpx;
  background: #f5f5f7;
  text-align: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
}
.picker-cancel:active { background: #e5e7eb; }
