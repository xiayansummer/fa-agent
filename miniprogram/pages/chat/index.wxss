page { background: var(--bg-base); }
.chat {
  display: flex; flex-direction: column;
  height: 100vh;
  padding-bottom: 0; /* 由 scroll-view 自己处理 */
}
.messages {
  flex: 1;
  padding: 32rpx;
  padding-bottom: 140rpx; /* 给输入栏留空间 */
  height: 0;  /* flex shrinking 关键 */
}

.user-bubble {
  align-self: flex-end;
  background: var(--agent-orchestrator); color: #fff;
  padding: 16rpx 24rpx; border-radius: 16rpx;
  max-width: 80%;
  margin: 16rpx 0 16rpx auto;
  font-size: 28rpx;
  line-height: 1.6;
  display: inline-block;
}

.agent-text {
  background: #fff; padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx; line-height: 1.7;
  border-left: 8rpx solid var(--agent-content);
}

.input-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff; padding: 20rpx 24rpx;
  display: flex; gap: 16rpx;
  border-top: 1rpx solid var(--border-light);
  z-index: 10;
}
.input {
  flex: 1; height: 72rpx;
  background: #f5f5f7; border-radius: 36rpx;
  padding: 0 24rpx; font-size: 28rpx;
}
.send-btn {
  background: var(--agent-orchestrator);
  color: #fff;
  padding: 0 32rpx;
  height: 72rpx; line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
}
