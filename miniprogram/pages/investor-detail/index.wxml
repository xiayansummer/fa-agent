<view class="detail" wx:if="{{investor}}">
  <view class="header">
    <image wx:if="{{investor.avatar_url}}" class="avatar avatar-img" src="{{investor.avatar_url}}" mode="aspectFill" />
    <view wx:else class="avatar">{{investor.name[0]}}</view>
    <view class="info">
      <view class="name">{{investor.name}}</view>
      <view class="position">{{investor.agency || ''}}{{investor.position ? ' · ' + investor.position : ''}}</view>
    </view>
    <view class="edit-btn" bindtap="onEdit">编辑</view>
  </view>

  <view class="meta-row">
    <view wx:if="{{investor.familiarity}}" class="familiarity-chip">{{investor.familiarity}}</view>
    <view wx:for="{{investor.industry_tags}}" wx:key="*this" class="tag">{{item}}</view>
  </view>

  <view class="section card-section" wx:if="{{investor.business_card_url}}">
    <view class="section-title">名片</view>
    <image
      class="business-card"
      src="{{investor.business_card_url}}"
      mode="widthFix"
      bindtap="previewCard"
      data-url="{{investor.business_card_url}}" />
  </view>

  <view class="section" wx:if="{{profileLines.length > 0}}">
    <view class="section-title">AI 偏好画像 ✦</view>
    <view wx:for="{{profileLines}}" wx:key="*this" class="profile-line">{{item}}</view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">近期互动</view>
      <view class="add-link" bindtap="onAddInteraction">+ 记互动</view>
    </view>
    <view wx:if="{{interactions.length === 0}}" class="empty">还没有互动记录</view>
    <view wx:for="{{interactions}}" wx:key="id" class="interaction">
      <view class="i-head">
        <view class="i-date">[{{item.dateLabel}}]</view>
        <view class="i-type">{{item.typeLabel}}</view>
      </view>
      <view class="i-summary">{{item.summary || '（无摘要）'}}</view>
    </view>
  </view>

  <view class="section" wx:if="{{qmingpianSummaries.length > 0}}">
    <view class="section-title">投资人纪要 · 来自企名片</view>
    <view wx:for="{{qmingpianSummaries}}" wx:key="created_at" class="qm-summary">
      <view class="qm-head">
        <view class="qm-creator">{{item.creator || '—'}}</view>
        <view class="qm-time">{{item.created_at}}</view>
      </view>
      <view class="qm-content">{{item.content}}</view>
    </view>
  </view>

  <view class="section" wx:if="{{qmingpianHistory.length > 0}}">
    <view class="section-title">历史推荐 · 来自企名片</view>
    <view wx:for="{{qmingpianHistory}}" wx:key="contact_time" class="qm-history">
      <view class="qm-head">
        <view class="qm-event">{{item.event}}</view>
        <view wx:if="{{item.status}}" class="qm-status">{{item.status}}</view>
      </view>
      <view wx:if="{{item.feedback}}" class="qm-feedback">{{item.feedback}}</view>
      <view class="qm-meta">
        <text wx:if="{{item.round}}">{{item.round}}</text>
        <text wx:if="{{item.contact_time}}"> · {{item.contact_time}}</text>
      </view>
    </view>
  </view>

  <view class="bottom-bar">
    <view class="ask-btn" bindtap="onAskAgent">✦ 问 Agent 关于 {{investor.name}}</view>
  </view>
</view>
