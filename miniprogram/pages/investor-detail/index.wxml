<view class="detail" wx:if="{{investor}}">
  <view class="header">
    <image wx:if="{{investor.avatar_url}}" class="avatar avatar-img" src="{{investor.avatar_url}}" mode="aspectFill" />
    <view wx:else class="avatar">{{investor.name[0]}}</view>
    <view class="info">
      <view class="name">{{investor.name}}</view>
      <view class="position">{{investor.agency || ''}}{{investor.position ? ' · ' + investor.position : ''}}</view>
    </view>
    <view class="edit-btn" bindtap="onEdit">编辑</view>
  </view>

  <view class="meta-row">
    <view wx:if="{{investor.familiarity}}" class="familiarity-chip">{{investor.familiarity}}</view>
    <view wx:for="{{investor.industry_tags}}" wx:key="*this" class="tag">{{item}}</view>
  </view>

  <view class="section card-section" wx:if="{{displayCardUrl}}">
    <view class="section-head">
      <view class="section-title">名片{{qmingpianCards.length > 1 ? ' · 共 ' + qmingpianCards.length + ' 张' : ''}}</view>
    </view>
    <image
      class="business-card"
      src="{{displayCardUrl}}"
      mode="widthFix"
      bindtap="previewCard"
      data-url="{{displayCardUrl}}" />
    <scroll-view wx:if="{{qmingpianCards.length > 1}}" scroll-x class="card-thumbs">
      <image
        wx:for="{{qmingpianCards}}"
        wx:key="*this"
        class="card-thumb"
        src="{{item}}"
        mode="aspectFill"
        data-url="{{item}}"
        bindtap="onSwitchCard" />
    </scroll-view>
  </view>

  <view class="section" wx:if="{{contactPhones.length > 0 || contactEmails.length > 0 || contactWechats.length > 0}}">
    <view class="section-title">联系方式</view>
    <view wx:for="{{contactPhones}}" wx:key="*this" wx:for-item="p" class="contact-row" data-val="{{p}}" data-type="phone" bindtap="onContactTap">
      <view class="contact-label">手机</view>
      <view class="contact-val">{{p}}</view>
      <view class="contact-action">复制</view>
    </view>
    <view wx:for="{{contactWechats}}" wx:key="*this" wx:for-item="w" class="contact-row" data-val="{{w}}" data-type="wechat" bindtap="onContactTap">
      <view class="contact-label">微信</view>
      <view class="contact-val">{{w}}</view>
      <view class="contact-action">复制</view>
    </view>
    <view wx:for="{{contactEmails}}" wx:key="*this" wx:for-item="e" class="contact-row" data-val="{{e}}" data-type="email" bindtap="onContactTap">
      <view class="contact-label">邮箱</view>
      <view class="contact-val">{{e}}</view>
      <view class="contact-action">复制</view>
    </view>
  </view>

  <view class="section" wx:if="{{profileLines.length > 0}}">
    <view class="section-title">AI 偏好画像 ✦</view>
    <view wx:for="{{profileLines}}" wx:key="*this" class="profile-line">{{item}}</view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">近期互动</view>
      <view class="add-link" bindtap="onAddInteraction">+ 记互动</view>
    </view>
    <view wx:if="{{interactions.length === 0}}" class="empty">还没有互动记录</view>
    <view wx:for="{{interactions}}" wx:key="id" class="interaction">
      <view class="i-head">
        <view class="i-date">[{{item.dateLabel}}]</view>
        <view class="i-type">{{item.typeLabel}}</view>
        <view class="i-del" catchtap="onDeleteInteraction" data-id="{{item.id}}">删除</view>
      </view>
      <view class="i-summary">{{item.summary || '（无摘要）'}}</view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">团队熟悉度 · 来自企名片</view>
    <view class="fam-list" wx:if="{{qmingpianFamiliar.length > 0}}">
      <view wx:for="{{qmingpianFamiliar}}" wx:key="name" class="fam-row">
        <view class="fam-name">{{item.name}}</view>
        <view class="fam-level">{{item.level}}</view>
      </view>
    </view>
    <view class="fam-empty" wx:else>暂无团队成员记录熟悉度</view>
  </view>

  <view class="section" wx:if="{{qmingpianSummaries.length > 0}}">
    <view class="section-title">投资人纪要 · 来自企名片</view>
    <view wx:for="{{qmingpianSummaries}}" wx:key="created_at" class="qm-summary">
      <view class="qm-head">
        <view class="qm-creator">{{item.creator || '—'}}</view>
        <view class="qm-time">{{item.created_at}}</view>
      </view>
      <view class="qm-content">{{item.content}}</view>
    </view>
  </view>

  <view class="section" wx:if="{{qmingpianHistory.length > 0}}">
    <view class="section-title">历史推荐 · 来自企名片</view>
    <view wx:for="{{qmingpianHistory}}" wx:key="contact_time" class="qm-history">
      <view class="qm-head">
        <view class="qm-event">{{item.event}}</view>
        <view wx:if="{{item.status}}" class="qm-status">{{item.status}}</view>
      </view>
      <view wx:if="{{item.feedback}}" class="qm-feedback">{{item.feedback}}</view>
      <view class="qm-meta">
        <text wx:if="{{item.round}}">{{item.round}}</text>
        <text wx:if="{{item.contact_time}}"> · {{item.contact_time}}</text>
      </view>
    </view>
  </view>

  <view class="bottom-bar">
    <view class="ask-btn" bindtap="onAskAgent">✦ 问 Agent 关于 {{investor.name}}</view>
  </view>
</view>
