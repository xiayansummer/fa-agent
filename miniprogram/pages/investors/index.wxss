page { background: var(--bg-base); }
.investors { padding: 32rpx; }
.header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.title { font-size: 36rpx; font-weight: 700; }
.add-btn { color: var(--agent-orchestrator); font-size: 28rpx; }

.search-bar {
  margin-bottom: 16rpx;
  position: relative;
  display: flex;
  align-items: center;
}
.search-input {
  flex: 1;
  background: #fff; padding: 20rpx 24rpx; border-radius: 12rpx;
  font-size: 28rpx;
}
.search-clear {
  position: absolute;
  right: 24rpx;
  width: 40rpx; height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  color: var(--text-secondary);
  background: #e5e5ea;
  border-radius: 50%;
  font-size: 24rpx;
}

.search-hint {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  padding-left: 8rpx;
}
.hit-card { gap: 16rpx; }
.hit-card.is-local { background: #f0f9ff; }

.badge {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
  margin-left: 8rpx;
}
.badge.in-lib { background: #dcfce7; color: #16a34a; }
.badge.ext { background: #fef3c7; color: #c2410c; }

.quick-add {
  flex-shrink: 0;
  padding: 12rpx 20rpx;
  background: var(--agent-orchestrator);
  color: #fff;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
}
.quick-add.busy { opacity: 0.5; }

.tags-row {
  white-space: nowrap; margin-bottom: 24rpx;
}
.tag {
  display: inline-block;
  padding: 8rpx 20rpx; margin-right: 12rpx;
  border-radius: 20rpx;
  background: #fff;
  color: var(--text-secondary);
  font-size: 24rpx;
}
.tag.selected {
  background: var(--agent-list);
  color: #fff;
}

.list { display: flex; flex-direction: column; gap: 12rpx; }
.card {
  background: #fff; border-radius: 16rpx; padding: 24rpx;
  display: flex; gap: 20rpx; align-items: center;
}
.avatar {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 32rpx; font-weight: 700;
  flex-shrink: 0;
}
.avatar-0 { background: #6B7AFF; }
.avatar-1 { background: #8B5CF6; }
.avatar-2 { background: #10B981; }
.avatar-3 { background: #F59E0B; }
.avatar-img { background: #f5f5f7; }

.info { flex: 1; min-width: 0; }
.row1 { display: flex; justify-content: space-between; }
.name { font-size: 30rpx; font-weight: 600; }
.last { font-size: 22rpx; color: var(--text-secondary); }
.row2 { font-size: 24rpx; color: var(--text-secondary); margin-top: 4rpx; }
.tags { display: flex; gap: 8rpx; margin-top: 8rpx; flex-wrap: wrap; }
.mini-tag {
  font-size: 20rpx; padding: 2rpx 12rpx;
  background: #e0e7ff; color: #6B7AFF;
  border-radius: 4rpx;
}
.mini-tag.fam {
  background: #fef3c7; color: #c2410c;
}

.empty {
  text-align: center; padding: 120rpx 32rpx;
  color: var(--text-secondary); font-size: 26rpx;
}
.footer {
  text-align: center;
  padding: 40rpx 0;
  color: var(--text-secondary);
  font-size: 22rpx;
}
