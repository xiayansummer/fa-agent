<view class="investors">
  <view class="header">
    <view class="title">投资人库</view>
    <view class="add-btn" bindtap="onAdd">+ 新增</view>
  </view>

  <view class="search-bar">
    <input
      class="search-input"
      placeholder="搜索企名片全库..."
      value="{{search}}"
      bindinput="onSearchInput"
      bindconfirm="onSearchConfirm"
      confirm-type="search" />
    <view wx:if="{{inSearchMode}}" class="search-clear" bindtap="onSearchClear">✕</view>
  </view>

  <!-- 标签筛选只在非搜索模式显示 -->
  <scroll-view wx:if="{{!inSearchMode}}" scroll-x class="tags-row">
    <view
      wx:for="{{allTags}}"
      wx:key="*this"
      class="tag {{selectedTags.indexOf(item) >= 0 ? 'selected' : ''}}"
      data-tag="{{item}}"
      bindtap="onTagTap">
      {{item}}{{selectedTags.indexOf(item) >= 0 ? ' ✓' : ''}}
    </view>
  </scroll-view>

  <!-- 搜索模式：显示企名片搜索结果 -->
  <view wx:if="{{inSearchMode}}" class="list">
    <view class="search-hint">企名片全库结果：</view>
    <view
      wx:for="{{searchHits}}"
      wx:key="qmingpian_person_id"
      class="card hit-card {{item.isLocal ? 'is-local' : ''}}"
      data-hit="{{item}}"
      bindtap="onHitTap">
      <image wx:if="{{item.avatar_url}}" class="avatar avatar-img" src="{{item.avatar_url}}" mode="aspectFill" />
      <view wx:else class="avatar avatar-0">{{item.firstLetter}}</view>
      <view class="info">
        <view class="row1">
          <view class="name">{{item.name}}</view>
          <view wx:if="{{item.isLocal}}" class="badge in-lib">在我的库</view>
          <view wx:else class="badge ext">企名片</view>
        </view>
        <view class="row2">{{item.agencyOrEmpty}}{{item.position ? ' · ' + item.position : ''}}</view>
      </view>
      <view wx:if="{{!item.isLocal}}" class="quick-add {{adding === item.qmingpian_person_id ? 'busy' : ''}}"
            data-hit="{{item}}"
            catchtap="onQuickAdd">
        {{adding === item.qmingpian_person_id ? '...' : '+ 加入'}}
      </view>
    </view>
    <view wx:if="{{searchHits.length === 0 && !loading}}" class="empty">
      企名片未找到匹配的人，可以「+ 新增」直接录入
    </view>
  </view>

  <!-- 非搜索模式：本地库列表 -->
  <view wx:else class="list">
    <view
      wx:for="{{investors}}"
      wx:key="id"
      class="card"
      data-id="{{item.id}}"
      bindtap="onInvestorTap">
      <image wx:if="{{item.avatar_url}}" class="avatar avatar-img" src="{{item.avatar_url}}" mode="aspectFill" />
      <view wx:else class="avatar avatar-{{item.id % 4}}">{{item.firstLetter}}</view>
      <view class="info">
        <view class="row1">
          <view class="name">{{item.name}}</view>
          <view class="last">{{item.lastInteractionLabel}}</view>
        </view>
        <view class="row2">{{item.agencyPosition || '—'}}</view>
        <view class="tags">
          <view wx:if="{{item.familiarity}}" class="mini-tag fam">{{item.familiarity}}</view>
          <view wx:for="{{item.industry_tags}}" wx:for-item="t" wx:key="*this" class="mini-tag">{{t}}</view>
        </view>
      </view>
    </view>

    <view wx:if="{{investors.length === 0 && !loading}}" class="empty">
      还没有关注的投资人，搜索企名片 「+ 加入我的库」
    </view>
  </view>

  <view wx:if="{{!inSearchMode && investors.length > 0}}" class="footer">
    共 {{investors.length}} 位投资人 · ✦ 按上次沟通时间排序
  </view>
</view>
