<view class="page">
  <scroll-view scroll-x class="filter-row">
    <view
      wx:for="{{filterTypes}}"
      wx:key="value"
      class="chip {{filterType === item.value ? 'selected' : ''}}"
      data-value="{{item.value}}"
      bindtap="onFilterTap">
      {{item.label}}
    </view>
  </scroll-view>

  <view class="list">
    <view wx:if="{{records.length === 0 && !loading}}" class="empty">
      没有草稿记录
    </view>
    <view
      wx:for="{{records}}"
      wx:key="id"
      class="swipe-row">
      <view class="delete-bg" catchtap="onDeleteTap" data-id="{{item.id}}">删除</view>
      <view
        class="card {{swipeOpenId === item.id ? 'swiped' : ''}}"
        data-item="{{item}}"
        data-id="{{item.id}}"
        bindtap="onItemTap"
        bindtouchstart="onTouchStart"
        bindtouchmove="onTouchMove">
        <view class="card-head">
          <view class="type-tag">{{item.typeLabel}}</view>
          <view wx:if="{{item.unboundLabel}}" class="unbound-tag">{{item.unboundLabel}}</view>
          <view class="status" style="color: {{item.statusColor}}">{{item.statusLabel}}</view>
          <view class="date">{{item.createdLabel}}</view>
        </view>
        <view class="content-preview">{{item.contentPreview}}{{item.content.length > 80 ? '...' : ''}}</view>
      </view>
    </view>
  </view>
</view>
