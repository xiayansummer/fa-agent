page { background: var(--bg-base); }
.page { padding: 0; min-height: 100vh; }

.filter-row {
  white-space: nowrap;
  background: #fff;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--border-light);
}
.chip {
  display: inline-block;
  padding: 8rpx 20rpx;
  margin-right: 12rpx;
  background: #f5f5f7;
  color: var(--text-secondary);
  border-radius: 20rpx;
  font-size: 24rpx;
}
.chip.selected {
  background: var(--agent-orchestrator);
  color: #fff;
}

.list { padding: 16rpx; }

.swipe-row {
  position: relative;
  margin-bottom: 12rpx;
  border-radius: 16rpx;
  overflow: hidden;
}
.delete-bg {
  position: absolute;
  right: 0; top: 0; bottom: 0;
  width: 140rpx;
  background: #ef4444;
  color: #fff;
  font-size: 26rpx;
  display: flex; align-items: center; justify-content: center;
  z-index: 1;
}
.card {
  position: relative;
  z-index: 2;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  transform: translateX(0);
  transition: transform 0.2s ease;
}
.card.swiped { transform: translateX(-140rpx); }
.card-head {
  display: flex; align-items: center; gap: 12rpx;
  margin-bottom: 12rpx;
}
.type-tag {
  background: #e0e7ff;
  color: #6B7AFF;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
}
.unbound-tag {
  background: #fef3c7;
  color: #c2410c;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
}
.status { font-size: 22rpx; font-weight: 600; }
.date {
  flex: 1; text-align: right;
  font-size: 22rpx;
  color: var(--text-secondary);
}
.content-preview {
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--text-primary);
}

.empty {
  text-align: center;
  padding: 120rpx 32rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
}
