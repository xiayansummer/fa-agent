<view class="edit">
  <view class="section">
    <view class="row">
      <view class="label">姓名 <text class="req">*</text></view>
      <input class="input" value="{{form.name}}" data-field="name" bindinput="onField" placeholder="姓名" />
    </view>
    <view class="row">
      <view class="label">机构</view>
      <input class="input" value="{{form.agency}}" data-field="agency" bindinput="onField" placeholder="如：红杉资本" />
    </view>
    <view class="row">
      <view class="label">职务</view>
      <picker mode="selector" range="{{positionOptions}}" bindchange="onPositionChange">
        <view class="picker-display">{{form.position || '请选择职务'}}</view>
      </picker>
      <view wx:if="{{form.position}}" class="clear-x" catchtap="onPositionClear">×</view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">熟悉度</view>
    <view class="tag-grid">
      <view
        wx:for="{{familiarityOptions}}"
        wx:key="*this"
        class="tag {{form.familiarity === item ? 'selected' : ''}}"
        data-value="{{item}}"
        bindtap="onFamiliarityTap">{{item}}</view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">名片</view>
    <view class="img-pickers">
      <view class="img-picker">
        <view wx:if="{{form.business_card_url}}" class="img-thumb-wrap">
          <image class="img-thumb wide" src="{{form.business_card_url}}" mode="widthFix" />
          <view class="img-clear" catchtap="onClearCard">×</view>
        </view>
        <view wx:else class="img-add wide" bindtap="onPickCard">+ 上传名片</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">投资人标签 · 同步至企名片</view>
    <view class="qm-tag-list">
      <view wx:for="{{form.qmingpian_tags}}" wx:key="*this" class="qm-tag">
        {{item}}
        <text class="qm-tag-x" data-tag="{{item}}" catchtap="onTagRemove">×</text>
      </view>
      <view wx:if="{{form.qmingpian_tags.length === 0}}" class="qm-tag-empty">暂无标签</view>
    </view>
    <view class="qm-tag-input-row">
      <input
        class="qm-tag-input"
        value="{{tagInput}}"
        placeholder="输入新标签，如 美元 / 消费品牌"
        bindinput="onTagInput"
        bindconfirm="onTagAdd"
        confirm-type="done" />
      <view class="qm-tag-add {{tagInput ? '' : 'disabled'}}" bindtap="onTagAdd">+ 添加</view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">关注行业 · 来自企名片（只读）</view>
    <view wx:if="{{qmingpianIndustries.length > 0}}" class="qm-ind-list">
      <view wx:for="{{qmingpianIndustries}}" wx:key="*this" class="qm-ind">{{item}}</view>
    </view>
    <view wx:else class="qm-tag-empty">企名片暂无行业偏好信息</view>
  </view>

  <view class="section">
    <view class="section-title">阶段偏好</view>
    <view class="tag-grid">
      <view
        wx:for="{{stageOptions}}"
        wx:key="*this"
        class="tag {{form.stage_pref.indexOf(item) >= 0 ? 'selected' : ''}}"
        data-field="stage_pref"
        data-tag="{{item}}"
        bindtap="onTagToggle">{{item}}</view>
    </view>
  </view>

  <view class="section">
    <view class="row">
      <view class="label">生日</view>
      <picker mode="date" value="{{form.birthday}}" bindchange="onBirthdayChange">
        <view class="picker-display">{{form.birthday || '未填'}}</view>
      </picker>
    </view>
  </view>

  <view class="section">
    <view class="section-title">AI 偏好画像 / 备注</view>
    <textarea
      class="textarea"
      value="{{form.profile_notes}}"
      data-field="profile_notes"
      bindinput="onField"
      placeholder="一行一条，AI 会用于个性化推送"
      auto-height />
  </view>

  <view class="bottom">
    <view wx:if="{{isEdit}}" class="del-btn" bindtap="onDelete">删除投资人</view>
    <view class="save-btn {{saving ? 'disabled' : ''}}" bindtap="{{saving ? '' : 'onSave'}}">
      {{saving ? '保存中...' : '保存'}}
    </view>
  </view>
</view>
