page { background: var(--bg-base); }
.edit { padding: 0 0 200rpx; min-height: 100vh; }

.section {
  background: #fff;
  margin: 16rpx;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
}
.section-title {
  font-size: 26rpx; color: var(--text-secondary);
  padding: 12rpx 0;
}

.row {
  display: flex; align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}
.row:last-child { border-bottom: none; }
.label { width: 180rpx; font-size: 28rpx; color: var(--text-primary); }
.req { color: #DC2626; }
.input { flex: 1; font-size: 28rpx; }
.picker-display { flex: 1; font-size: 28rpx; color: var(--text-secondary); }

.score-bar { display: flex; gap: 8rpx; }
.score-dot {
  font-size: 32rpx;
  color: var(--border-light);
  padding: 0 4rpx;
}
.score-dot.on { color: var(--agent-orchestrator); }

.tag-grid { display: flex; flex-wrap: wrap; gap: 12rpx; padding: 8rpx 0 16rpx; }
.tag {
  background: #f5f5f7;
  color: var(--text-secondary);
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}
.tag.selected {
  background: var(--agent-orchestrator);
  color: #fff;
}

.textarea {
  width: 100%; box-sizing: border-box;
  background: #f5f5f7;
  padding: 16rpx; border-radius: 12rpx;
  font-size: 26rpx; line-height: 1.7;
  min-height: 200rpx;
}

.bottom {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff;
  padding: 20rpx 32rpx;
  display: flex; gap: 16rpx;
  border-top: 1rpx solid var(--border-light);
}
.del-btn {
  flex: 1; padding: 24rpx 0;
  text-align: center;
  background: #FEE2E2;
  color: #DC2626;
  border-radius: 12rpx;
  font-size: 28rpx;
}
.save-btn {
  flex: 2; padding: 24rpx 0;
  text-align: center;
  background: var(--agent-orchestrator);
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx; font-weight: 600;
}
.save-btn.disabled { opacity: 0.5; }
