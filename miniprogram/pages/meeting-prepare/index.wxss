page { background: var(--bg-base); }
.page { padding: 32rpx; min-height: 100vh; }

.title {
  font-size: 32rpx; font-weight: 600;
  margin-bottom: 24rpx;
}

.mode-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
}
.mode-card.paste-card { padding: 0; }

.mode-row {
  display: flex; align-items: center; gap: 20rpx;
  padding: 28rpx 24rpx;
}
.mode-card:not(.paste-card) {
  display: flex; align-items: center; gap: 20rpx;
}

.mode-icon { font-size: 40rpx; }
.mode-body { flex: 1; }
.mode-title { font-size: 30rpx; font-weight: 600; }
.mode-desc { font-size: 24rpx; color: var(--text-secondary); margin-top: 6rpx; }
.mode-arrow {
  font-size: 32rpx;
  color: var(--text-secondary);
}

.paste-area {
  border-top: 1rpx solid var(--border-light);
  padding: 24rpx;
}
.paste-textarea {
  width: 100%; box-sizing: border-box;
  background: #f5f5f7;
  padding: 16rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  min-height: 300rpx;
}
.paste-submit {
  margin-top: 16rpx;
  padding: 20rpx 0;
  background: var(--agent-orchestrator);
  color: #fff;
  text-align: center;
  border-radius: 12rpx;
  font-size: 28rpx; font-weight: 600;
}
.paste-submit.disabled { opacity: 0.5; }

.hint {
  margin-top: 32rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-secondary);
}
