.day-page { padding: 32rpx; min-height: 100vh; background: var(--bg-base); }
.header { margin-bottom: 32rpx; }
.date { font-size: 36rpx; font-weight: 700; }
.hint { color: var(--agent-orchestrator); font-size: 24rpx; margin-top: 12rpx; }
.empty {
  text-align: center; padding: 120rpx 0;
  color: var(--text-secondary); font-size: 28rpx;
}
.event-card {
  background: #fff; border-radius: 16rpx; padding: 32rpx;
  margin-bottom: 20rpx;
  position: relative;
}
.event-close {
  position: absolute;
  top: 16rpx; right: 24rpx;
  width: 48rpx; height: 48rpx;
  line-height: 44rpx; text-align: center;
  color: #9ca3af; font-size: 36rpx; font-weight: 400;
  border-radius: 50%;
}
.event-close:active { background: #f3f4f6; color: #ef4444; }
.event-head { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.time { font-size: 28rpx; color: var(--text-secondary); font-family: monospace; }
.tag {
  color: #fff; font-size: 22rpx;
  padding: 4rpx 16rpx; border-radius: 8rpx;
}
.event-title { font-size: 30rpx; font-weight: 600; margin-bottom: 8rpx; }
.event-desc { color: var(--text-secondary); font-size: 26rpx; line-height: 1.6; }
.action-btn {
  margin-top: 24rpx;
  color: #fff; text-align: center;
  font-size: 26rpx; padding: 16rpx 0;
  border-radius: 12rpx; font-weight: 500;
}
