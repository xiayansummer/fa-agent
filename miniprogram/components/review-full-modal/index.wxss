.modal-mask {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex; align-items: flex-end;
}
.modal {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  height: 90vh;
  display: flex; flex-direction: column;
}
.modal-head {
  display: flex; align-items: center; gap: 16rpx;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--border-light);
}
.close { font-size: 48rpx; color: var(--text-secondary); padding: 0 16rpx; }
.agent-title { flex: 1; font-size: 28rpx; font-weight: 600; }
.quick-actions { display: flex; gap: 12rpx; }
.quick-btn {
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
}
.quick-btn.approve { background: #dcfce7; color: #16a34a; }
.quick-btn.reject { background: #fee2e2; color: #DC2626; }

.modal-textarea {
  flex: 1;
  width: 100%; box-sizing: border-box;
  padding: 32rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.7;
  background: #fff;
  height: 100%;
}

.modal-footer {
  display: flex; gap: 16rpx;
  padding: 24rpx;
  border-top: 1rpx solid var(--border-light);
}
.footer-btn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx; font-weight: 600;
}
.footer-btn.ghost {
  background: #f5f5f7; color: var(--text-primary);
}
.footer-btn.primary {
  background: var(--agent-orchestrator); color: #fff;
}
.footer-btn.disabled { opacity: 0.5; }
