<view class="card agent-{{agent}}">
  <view class="card-head">
    <view class="avatar avatar-{{agent}}">
      <text wx:if="{{agent === 'orchestrator'}}">O</text>
      <text wx:elif="{{agent === 'list'}}">名</text>
      <text wx:elif="{{agent === 'content'}}">内</text>
      <text wx:elif="{{agent === 'outreach'}}">触</text>
    </view>
    <view class="agent-name">{{title}}</view>
    <view wx:if="{{showStatus}}" class="status">{{showStatus}}</view>
  </view>

  <view class="card-body" wx:if="{{!editing}}">
    <slot wx:if="{{!body}}"></slot>
    <text wx:else>{{body}}</text>
  </view>

  <view class="edit-area" wx:if="{{editing}}">
    <textarea
      class="edit-textarea"
      value="{{editText}}"
      bindinput="onEditInput"
      auto-height
      maxlength="-1" />
    <view class="edit-actions">
      <view class="action-btn" data-action="cancel_modify" bindtap="onAction">取消</view>
      <view class="action-btn primary" data-action="submit_modify" bindtap="onAction">
        {{submitting ? '提交中...' : '提交修改'}}
      </view>
    </view>
  </view>

  <view class="actions" wx:if="{{actions.length > 0 && !showStatus && !editing}}">
    <view
      wx:for="{{actions}}"
      wx:key="action"
      class="action-btn {{item.primary ? 'primary' : ''}} {{submitting ? 'disabled' : ''}}"
      data-action="{{item.action}}"
      bindtap="{{submitting ? '' : 'onAction'}}">
      {{item.label}}
    </view>
  </view>
</view>
