.card {
  background: #fff; border-radius: 16rpx;
  padding: 24rpx; margin-bottom: 16rpx;
  border-left: 8rpx solid var(--agent-orchestrator);
}
.agent-orchestrator { border-left-color: #6B7AFF; }
.agent-list { border-left-color: #8B5CF6; }
.agent-content { border-left-color: #374151; }
.agent-outreach { border-left-color: #F59E0B; }

.card-head { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.avatar {
  width: 48rpx; height: 48rpx; border-radius: 8rpx;
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 22rpx; font-weight: 600;
}
.avatar-orchestrator { background: #6B7AFF; }
.avatar-list { background: #8B5CF6; }
.avatar-content { background: #374151; }
.avatar-outreach { background: #F59E0B; }

.agent-name { font-size: 26rpx; color: var(--text-secondary); flex: 1; }
.status {
  font-size: 22rpx; color: #16a34a; background: #dcfce7;
  padding: 4rpx 16rpx; border-radius: 8rpx;
}

.card-body { font-size: 28rpx; line-height: 1.7; color: var(--text-primary); }

.actions { display: flex; gap: 12rpx; margin-top: 24rpx; }
.action-btn {
  flex: 1;
  padding: 16rpx 0;
  border-radius: 12rpx;
  text-align: center;
  font-size: 26rpx;
  background: #f5f5f7;
  color: var(--text-primary);
}
.action-btn.primary { background: var(--agent-orchestrator); color: #fff; }
