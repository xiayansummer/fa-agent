# MySQL
MYSQL_ROOT_PASSWORD=changeme
MYSQL_URL=mysql+aiomysql://root:changeme@mysql:3306/fa_agent

# Redis
REDIS_URL=redis://redis:6379/0

# WeChat Mini-Program
WECHAT_APPID=wx_your_appid
WECHAT_SECRET=your_wechat_secret

# JWT
JWT_SECRET_KEY=change-this-to-a-random-secret-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# AI Provider (OpenAI-compatible: Anthropic / 阿里云DashScope / etc)
AI_API_KEY=sk-your-key
AI_BASE_URL=https://api.anthropic.com/v1
AI_MODEL=claude-sonnet-4-6

# Internal API base — celery beat tasks self-call FastAPI via this URL
INTERNAL_API_BASE=http://127.0.0.1:8000

# Qiniu (file uploads — bucket "file" in 华东-浙江 = z0)
QINIU_AK=your-access-key
QINIU_SK=your-secret-key
QINIU_BUCKET=file
QINIU_REGION=z0
QINIU_DOMAIN=https://files.your-domain.com  # bound CNAME for private downloads

# Tavily
TAVILY_API_KEY=tvly-your-key

# 企名片 (Investarget API — QMINGPIAN_TOKEN is the open_id value)
QMINGPIAN_TOKEN=your-open-id

# ASR (DashScope Qwen3-ASR-Flash)
ASR_API_KEY=sk-your-dashscope-key
ASR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ASR_MODEL=qwen3-asr-flash

# 腾讯会议
TENCENT_MEETING_APP_ID=your-app-id
TENCENT_MEETING_SECRET_ID=your-secret-id
TENCENT_MEETING_SECRET_KEY=your-secret-key

# AES encryption key for storing user tokens (Tencent meeting etc).
# Generate with: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# WARNING: losing this key invalidates all encrypted tokens stored in the DB
TOKEN_ENCRYPT_KEY=
